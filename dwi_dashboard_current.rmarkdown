# Map

## Row {height=100%}

### Column {.tabset width=75%}

```{r}
#| title: YTD Crashes
map_data <- crash_level %>%
  filter(City == "El Paso",
         Crash.Year == 2026) %>%
  mutate(
    Latitude = as.numeric(Latitude),
    Longitude = as.numeric(Longitude)
  ) %>%
  filter(!is.na(Latitude), !is.na(Longitude))

leaflet(map_data) %>%
  addProviderTiles(providers$CartoDB.Positron) %>%
  
  addCircleMarkers(
    lng = ~Longitude,
    lat = ~Latitude,
    radius = 3,
    stroke = FALSE,
    fillOpacity = 0.4,
    color = "black"
  ) %>%
  
  setView(
    lng = mean(map_data$Longitude, na.rm = TRUE),
    lat = mean(map_data$Latitude, na.rm = TRUE),
    zoom = 11
  )
```

```{r}
#| title: YTD Fatal Crashes
map_data <- crash_level %>%
  filter(City == "El Paso",
         Crash.Year == 2026,
         Fatal.Crash.Flag == 1) %>%
  mutate(
    Latitude = as.numeric(Latitude),
    Longitude = as.numeric(Longitude)
  ) %>%
  filter(!is.na(Latitude), !is.na(Longitude))

leaflet(map_data) %>%
  addProviderTiles(providers$CartoDB.Positron) %>%
  
  addCircleMarkers(
    lng = ~Longitude,
    lat = ~Latitude,
    radius = 3,
    stroke = FALSE,
    fillOpacity = 0.4,
    color = "maroon"
  ) %>%
  
  setView(
    lng = mean(map_data$Longitude, na.rm = TRUE),
    lat = mean(map_data$Latitude, na.rm = TRUE),
    zoom = 11
  )
```

### Column {width=25%}

``` {r}
#| title: Streets with most alcohol-related crashes (YTD)
top_10_streets <- crash_level %>%
  filter(City == "El Paso",
         Crash.Year == 2026) %>%
  count(Street.Name, sort = TRUE) %>%
  mutate(
    percent = paste0(round((n / sum(n) * 100), 2), "%")
  ) %>%
  slice_head(n = 15)

datatable(
  top_10_streets,
  colnames = c("Name", "Count", "Percent"),
  options = list(
    pageLength = 15,
    searching = TRUE,
    dom = "tip"   # keeps search box, table info, pagination
  )
)
```


