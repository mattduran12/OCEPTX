files <- c(
austin = "C:/Users/Matt/ASU Dropbox/Matthew Duran/Professional Development/Website/Drunk Driving dashboard/data/austin_workingdata.csv",
brownsville = "C:/Users/Matt/ASU Dropbox/Matthew Duran/Professional Development/Website/Drunk Driving dashboard/data/brownsville_workingdata.csv",
dallas = "C:/Users/Matt/ASU Dropbox/Matthew Duran/Professional Development/Website/Drunk Driving dashboard/data/dallas_workingdata.csv",
elpaso = "C:/Users/Matt/ASU Dropbox/Matthew Duran/Professional Development/Website/Drunk Driving dashboard/data/elpaso_workingdata.csv",
fortworth = "C:/Users/Matt/ASU Dropbox/Matthew Duran/Professional Development/Website/Drunk Driving dashboard/data/fortworth_workingdata.csv",
houston = "C:/Users/Matt/ASU Dropbox/Matthew Duran/Professional Development/Website/Drunk Driving dashboard/data/houston_workingdata.csv",
laredo = "C:/Users/Matt/ASU Dropbox/Matthew Duran/Professional Development/Website/Drunk Driving dashboard/data/laredo_workingdata.csv",
mcallen = "C:/Users/Matt/ASU Dropbox/Matthew Duran/Professional Development/Website/Drunk Driving dashboard/data/mcallen_workingdata.csv",
sanantonio = "C:/Users/Matt/ASU Dropbox/Matthew Duran/Professional Development/Website/Drunk Driving dashboard/data/sanantonio_workingdata.csv"
)
all_cities <- bind_rows(lapply(names(files), function(city) {
df <- read.csv(files[[city]], header = TRUE)
df$city <- city
df
}))
all_cities$City <- recode(all_cities$City,
"AUSTIN" = "Austin",
"BROWNSVILLE" = "Brownsville",
"DALLAS" = "Dallas",
"EL PASO" = "El Paso",
"FORT WORTH" = "Fort Worth",
"HOUSTON" = "Houston",
"MCALLEN" = "McAllen",
"SAN ANTONIO" = "San Antonio",
"LAREDO" = "Laredo"
)
# drop current month, since its incomplete
all_cities <- all_cities %>%
mutate(
Crash.Date = mdy(Crash.Date)
) %>%
filter(
!(year(Crash.Date) == year(Sys.Date()) &
month(Crash.Date) == month(Sys.Date()))
)
person_level <- all_cities
vehicle_level <- all_cities %>%
distinct(Crash.ID, Unit.Number, .keep_all = TRUE)
crash_level <- all_cities %>%
distinct(Crash.ID, .keep_all = TRUE)
# ----------------------------
# REPORTING MONTH (DATA LAGS 1 MONTH)
# ----------------------------
report_date <- Sys.Date() %m-% months(1)
report_month <- format(report_date, "%B %Y")
report_year <- year(report_date)
prev_year <- report_year - 1
# ----------------------------
# MONTHLY DATA
# ----------------------------
this_month <- crash_level %>%
filter(
City == "El Paso",
year(Crash.Date) == report_year,
month(Crash.Date) == month(report_date)
)
last_month <- crash_level %>%
filter(
City == "El Paso",
year(Crash.Date) == year(report_date %m-% months(1)),
month(Crash.Date) == month(report_date %m-% months(1))
)
# ----------------------------
# METRICS
# ----------------------------
crashes_now <- n_distinct(this_month$Crash.ID)
crashes_prev <- n_distinct(last_month$Crash.ID)
# ----------------------------
# INJURIES (MATCH YOUR CLEAN LOGIC)
# ----------------------------
injuries_now <- person_level %>%
filter(
City == "El Paso",
year(Crash.Date) == report_year,
month(Crash.Date) == month(report_date),
!Person.Injury.Severity %in% c(
"99 - UNKNOWN",
"95 - AUTONOMOUS",
"N - NOT INJURED",
"K - FATAL INJURY"
),
!is.na(Person.Injury.Severity)
) %>%
summarise(n = n()) %>%
pull(n)
injuries_prev <- person_level %>%
filter(
City == "El Paso",
year(Crash.Date) == year(report_date %m-% months(1)),
month(Crash.Date) == month(report_date %m-% months(1)),
!Person.Injury.Severity %in% c(
"99 - UNKNOWN",
"95 - AUTONOMOUS",
"N - NOT INJURED",
"K - FATAL INJURY"
),
!is.na(Person.Injury.Severity)
) %>%
summarise(n = n()) %>%
pull(n)
# ----------------------------
# FATALITIES (KEEP CONSISTENT)
# ----------------------------
fatal_now <- person_level %>%
filter(
City == "El Paso",
year(Crash.Date) == report_year,
month(Crash.Date) == month(report_date),
Person.Injury.Severity == "K - FATAL INJURY"
) %>%
summarise(n = n()) %>%
pull(n)
fatal_prev <- person_level %>%
filter(
City == "El Paso",
year(Crash.Date) == year(report_date %m-% months(1)),
month(Crash.Date) == month(report_date %m-% months(1)),
Person.Injury.Severity == "K - FATAL INJURY"
) %>%
summarise(n = n()) %>%
pull(n)
# % changes
pct_change_crash <- ifelse(crashes_prev == 0, NA, (crashes_now - crashes_prev)/crashes_prev*100)
pct_change_injury <- ifelse(injuries_prev == 0, NA, (injuries_now - injuries_prev)/injuries_prev*100)
pct_change_fatal <- ifelse(fatal_prev == 0, NA, (fatal_now - fatal_prev)/fatal_prev*100)
fmt <- function(x) ifelse(is.na(x), "N/A", paste0(round(x,1), "%"))
# ----------------------------
# MONTHLY SERIES (CURRENT VS PRIOR YEAR)
# ----------------------------
build_monthly <- function(df, value){
df %>%
mutate(
year = year(Crash.Date),
month = month(Crash.Date)
) %>%
filter(year %in% c(report_year, prev_year)) %>%
group_by(year, month) %>%
summarise(val = {{value}}, .groups="drop") %>%
complete(year, month = 1:12, fill = list(val = 0)) %>%
mutate(
month_lab = factor(month.abb[month], levels = month.abb),
year = factor(year)
)
}
# crashes
crash_plot_data <- build_monthly(crash_level %>% filter(City=="El Paso"),
n_distinct(Crash.ID))
# fatalities
fatal_plot_data <- build_monthly(
person_level %>%
filter(City=="El Paso",
Person.Injury.Severity == "K - FATAL INJURY"),
n()
)
# injuries
injury_plot_data <- build_monthly(
person_level %>%
filter(
City=="El Paso",
!Person.Injury.Severity %in% c(
"99 - UNKNOWN",
"95 - AUTONOMOUS",
"N - NOT INJURED",
"K - FATAL INJURY"
),
!is.na(Person.Injury.Severity)
),
n()
)
# ----------------------------
# DIRECTION LABELS
# ----------------------------
dir_crash <- case_when(
is.na(pct_change_crash) ~ "",
pct_change_crash > 0 ~ "increase",
pct_change_crash < 0 ~ "decrease",
TRUE ~ "no change"
)
dir_fatal <- case_when(
is.na(pct_change_fatal) ~ "",
pct_change_fatal > 0 ~ "increase",
pct_change_fatal < 0 ~ "decrease",
TRUE ~ "no change"
)
dir_injury <- case_when(
is.na(pct_change_injury) ~ "",
pct_change_injury > 0 ~ "increase",
pct_change_injury < 0 ~ "decrease",
TRUE ~ "no change"
)
