library(tidyRSS)
library(dplyr)
library(stringr)
# ----------------------------
# RSS SOURCES (EN + ES)
# ----------------------------
rss_url_en <- "https://news.google.com/rss/search?q=(\"DWI\"%20OR%20\"DUI\"%20OR%20\"drunk%20driving\"%20OR%20\"impaired%20driving\")%20\"El%20Paso\"&hl=en-US&gl=US&ceid=US:en"
rss_url_es <- "https://news.google.com/rss/search?q=(\"DUI\"%20OR%20\"DWI\"%20OR%20\"manejar%20ebrio\"%20OR%20\"conducir%20ebrio\"%20OR%20\"conducci%C3%B3n%20bajo%20influencia\")%20\"El%20Paso\"&hl=es-419&gl=US&ceid=US:es"
# ----------------------------
# READ BOTH FEEDS
# ----------------------------
rss_en <- tidyfeed(rss_url_en)
rss_es <- tidyfeed(rss_url_es)
# ----------------------------
# COMBINE + CLEAN
# ----------------------------
rss_items <- bind_rows(rss_en, rss_es) %>%
select(item_title, item_link, item_pub_date) %>%
mutate(
# strip Google tracking params
clean_link = str_remove(item_link, "\\?.*$"),
# normalize title
clean_title = item_title %>%
str_to_lower() %>%
str_replace_all("[^a-z0-9 ]", "") %>%
str_squish(),
# extract news source (everything after last " - ")
source = item_title %>%
str_extract("-\\s*[^-]+$") %>%
str_remove("^-\\s*") %>%
str_squish() %>%
str_to_upper()
) %>%
# TRUE deduplication key (fixes your issue)
mutate(
story_key = paste(clean_title, source)
) %>%
distinct(story_key, .keep_all = TRUE) %>%
arrange(desc(item_pub_date)) %>%
slice_head(n = 500)
# ----------------------------
# HELPERS
# ----------------------------
clean_title <- function(full_title) {
parts <- str_split(full_title, " - ", simplify = TRUE)
if (ncol(parts) > 1) {
title <- parts[,1]
source <- parts[,ncol(parts)]
} else {
title <- full_title
source <- "Unknown"
}
list(title = title, source = toupper(source))
}
format_date <- function(x) {
format(as.Date(x), "%B %d, %Y")
}
get_tags(paste(
rss_items$item_title[i],
rss_items$item_description[i]
))
library(gt)
search_table <- data.frame(
Concept = c(
"Impaired Driving",
"Geographic Location",
"Prevalence / Outcomes",
"Risk Factors",
"Evaluations / Interventions"
),
Search_Strings = c(
"\"DWI\" OR \"DUI\" OR \"drunk driving\" OR \"impaired driving\" OR \"driving under the influence\" OR \"alcohol-impaired driving\" OR \"drug-impaired driving\"",
"\"El Paso\" AND \"Texas\"",
"prevalence OR incidence OR rate* OR trend* OR arrest* OR crash* OR collision* OR fatal* OR injur*",
"\"risk factor*\" OR predictor* OR correlat* OR determinant*",
"evaluat* OR intervention* OR program* OR policy OR enforcement OR \"sobriety checkpoint*\" OR campaign*"
),
Databases = c(
"EBSCO; Web of Science; Google Scholar",
"Same databases",
"Same databases",
"Same databases",
"Same databases"
)
)
gt(search_table) |>
tab_header(
title = "Table 1. Search Strategy"
) |>
cols_label(
Concept = "Concept",
Search_Strings = "Search Strings",
Databases = "Databases"
) |>
tab_options(
table.font.size = "small"
)
