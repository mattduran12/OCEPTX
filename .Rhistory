base <- crash_level %>%
filter(City == "El Paso",
Crash.Year != 2020) %>%
mutate(date = as.Date(Crash.Date),
year = year(date))
# ----------------------------
# 2. Memorial Day per year
# ----------------------------
memorial <- base %>%
distinct(year) %>%
mutate(
memorial_day = as.Date(paste0(year, "-05-31")) -
(wday(as.Date(paste0(year, "-05-31")), week_start = 1) - 1)
)
# ----------------------------
# 3. Event time
# ----------------------------
event_data <- base %>%
left_join(memorial, by = "year") %>%
mutate(event_time = as.numeric(date - memorial_day))
# ----------------------------
# 4. Keep ±7 day window
# ----------------------------
window_data <- event_data %>%
filter(event_time >= -7, event_time <= 7)
# ----------------------------
# 5. Collapse: daily totals per year
# ----------------------------
event_summary <- window_data %>%
group_by(year, event_time) %>%
summarise(crashes = n_distinct(Crash.ID), .groups = "drop")
# ----------------------------
# 6. Final estimate: average across years
# ----------------------------
final_plot_data <- event_summary %>%
group_by(event_time) %>%
summarise(avg_crashes = mean(crashes), .groups = "drop")
p <- ggplot(final_plot_data, aes(x = event_time, y = avg_crashes)) +
geom_line(color = "#2C3E50", linewidth = 1) +
geom_point(aes(color = event_time == 0), size = 2) +
geom_vline(xintercept = 0, linetype = "dashed", color = "red") +
scale_color_manual(values = c("TRUE" = "red", "FALSE" = "#2C3E50")) +
scale_x_continuous(breaks = seq(-7, 7, 1)) +
labs(
x = "Days from Memorial Day",
y = "Average crashes"
) +
theme_minimal() +
theme(
legend.position = "none"
)
