#| title: Crashes by Hour (YTD)
hour_data <- crash_level %>%
filter(
City == "El Paso",
Crash.Year == 2026
) %>%
mutate(
hour = as.numeric(substr(Hour.of.Day, 1, 2)),
time_block = case_when(
hour >= 0  & hour <= 2  ~ "12–3 AM",
hour >= 3  & hour <= 5  ~ "3–6 AM",
hour >= 6  & hour <= 8  ~ "6–9 AM",
hour >= 9  & hour <= 11 ~ "9 AM–12 PM",
hour >= 12 & hour <= 14 ~ "12–3 PM",
hour >= 15 & hour <= 17 ~ "3–6 PM",
hour >= 18 & hour <= 20 ~ "6–9 PM",
hour >= 21 & hour <= 23 ~ "9 PM–12 AM",
TRUE ~ "Unknown"
),
# enforce order
time_block = factor(
time_block,
levels = c(
"12–3 AM", "3–6 AM", "6–9 AM", "9 AM–12 PM",
"12–3 PM", "3–6 PM", "6–9 PM", "9 PM–12 AM"
)
)
) %>%
count(time_block)
avg_block <- mean(hour_data$n, na.rm = TRUE)
p4 <- ggplot(hour_data, aes(x = time_block, y = n)) +
geom_col(fill = "steelblue") +
geom_hline(
aes(yintercept = avg_block, color = "Average"),
linetype = "dashed",
linewidth = 1.2
) +
scale_color_manual(
values = c("Average" = "orange"),
name = ""
) +
theme_minimal() +
theme(
legend.position = "top",
axis.text.x = element_text(angle = 45, hjust = 1)
) +
labs(
x = "",
y = "Total crashes"
)
ggplotly(p4)
library(bsib)
install.packages("bsib")
suppressMessages(library(bslib))
theme_set(
theme_minimal(base_size = 12) +
theme(
plot.background = element_rect(fill = "transparent", color = NA),
panel.background = element_rect(fill = "transparent", color = NA),
panel.grid.major = element_line(color = "#333333"),
panel.grid.minor = element_line(color = "#222222"),
text = element_text(color = "#e6e6e6"),
axis.text = element_text(color = "#e6e6e6"),
axis.title = element_text(color = "#e6e6e6"),
plot.title = element_text(color = "#e6e6e6", face = "bold")
)
)
