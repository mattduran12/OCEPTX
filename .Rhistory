library(tidyRSS)
library(dplyr)
rss_url <- "https://news.google.com/rss/search?q=(\"DWI\"%20OR%20\"drunk%20driving\"%20OR%20\"impaired%20driving\")%20\"El%20Paso\"&hl=en-US&gl=US&ceid=US:en"
rss_items <- tidyfeed(rss_url) %>%
select(item_title, item_link, item_pub_date) %>%
slice_head(n = 10)
for (i in 1:nrow(rss_items)) {
cat(
paste0(
"<div style='
padding: 14px;
margin-bottom: 12px;
border: 1px solid #e5e7eb;
border-radius: 10px;
background-color: #ffffff;
'>",
"<a href='", rss_items$item_link[i], "' target='_blank' style='
font-weight: 600;
font-size: 1.05em;
color: #1a1a1a;
text-decoration: none;
'>",
rss_items$item_title[i],
"</a>",
"<div style='
margin-top: 6px;
color: #6b7280;
font-size: 0.85em;
'>",
rss_items$item_pub_date[i],
"</div>",
"</div>"
)
)
}
