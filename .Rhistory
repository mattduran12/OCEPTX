table.font.size = "small",
column_labels.font.weight = "bold",
column_labels.border.bottom.width = px(2),
table.border.top.style = "none",
table.border.bottom.style = "solid"
)
#| title: Intoxicated Driver's Zipcode (YTD)
zip_top10 <- drivers %>%
filter(bac_value >= 0.08 & bac_result == 1,
!is.na(Driver.Zip.Code)) %>%
group_by(Driver.Zip.Code) %>%
summarise(n = n(), .groups = "drop") %>%
arrange(desc(n)) %>%
slice_head(n = 10)
zip_top10 <- zip_top10 %>%
mutate(
pct = n / sum(n),
label_full = paste0(Driver.Zip.Code, "\n", n, " (", scales::percent(pct), ")")
)
plot_ly(
data = zip_top10,
type = "treemap",
labels = ~label_full,
parents = rep("", nrow(zip_top10)),
values = ~n,
textinfo = "label",
marker = list(colors = "#f4b942"),
hovertemplate = paste(
"ZIP: %{label}<br>",
"Drivers: %{value}<br>",
"<extra></extra>"
)
)
plot_ly(
data = zip_top10,
type = "treemap",
labels = ~label_full,
parents = rep("", nrow(zip_top10)),
values = ~n,
textinfo = "label",
marker = list(
colors = rep("#f4b942", nrow(zip_top10))
),
hovertemplate = paste(
"ZIP: %{label}<br>",
"Drivers: %{value}<br>",
"<extra></extra>"
)
)
