#| title: Holiday Crashes (Memorial Day)
# ----------------------------
# Step 1: Filter base data
# ----------------------------
crash_data <- crash_level %>%
filter(
City == "El Paso",
Crash.Year != 2020
) %>%
mutate(
date = as.Date(Crash.Date),
year = year(date)
)
# ----------------------------
# Step 2: Compute Memorial Day per year
# (last Monday in May)
# ----------------------------
holiday_calendar <- crash_data %>%
distinct(year) %>%
mutate(
memorial_day = as.Date(paste0(year, "-05-31")) -
(wday(as.Date(paste0(year, "-05-31")), week_start = 1) - 1)
)
# ----------------------------
# Step 3: Attach holiday + compute event time
# ----------------------------
event_data <- crash_data %>%
left_join(holiday_calendar, by = "year") %>%
mutate(
days_from_memorial = as.numeric(date - memorial_day)
) %>%
filter(days_from_memorial >= -7,
days_from_memorial <= 7)
# ----------------------------
# Step 4: Collapse to daily counts per year
# ----------------------------
plot_data <- event_data %>%
group_by(year, days_from_memorial) %>%
summarise(
daily_crashes = n_distinct(Crash.ID),
.groups = "drop"
) %>%
group_by(days_from_memorial) %>%
summarise(
avg_crashes = mean(daily_crashes),
.groups = "drop"
)
# ----------------------------
# Step 5: Final result (THIS is your answer)
# ----------------------------
plot_data
