suppressMessages(library(dplyr))
suppressMessages(library(lubridate))
suppressMessages(library(tidyr))
suppressMessages(library(readr))
# Load data
data <- read.csv("C:/Users/Matt/Documents/data/ep_data_(01-01-2016_05-02-2026).csv", header = TRUE)
# Clean + date conversion
data <- data %>%
mutate(
City = recode(City, "EL PASO" = "El Paso"),
Crash.Date = mdy(Crash.Date)
) %>%
filter(!(year(Crash.Date) == year(Sys.Date()) &
month(Crash.Date) == month(Sys.Date())))
# -------------------------
# LEVELS
# -------------------------
crash_level <- data %>%
distinct(Crash.ID, .keep_all = TRUE)
fatal_person_level <- data %>%
filter(Person.Injury.Severity == "K - FATAL INJURY")
# -------------------------
# MONTHLY TOTALS
# -------------------------
monthly_crashes <- crash_level %>%
mutate(month = floor_date(Crash.Date, "month")) %>%
filter(month >= as.Date("2021-01-01"),
month <= as.Date("2025-07-31")) %>%
group_by(month) %>%
summarise(total_crashes = n(), .groups = "drop")
monthly_fatalities <- fatal_person_level %>%
mutate(month = floor_date(Crash.Date, "month")) %>%
filter(month >= as.Date("2021-01-01"),
month <= as.Date("2025-07-31")) %>%
group_by(month) %>%
summarise(total_fatalities = n(), .groups = "drop")
# -------------------------
# FULL MONTH GRID
# -------------------------
all_months <- tibble(
month = seq.Date(as.Date("2021-01-01"),
as.Date("2025-07-01"),
by = "month")
)
df <- all_months %>%
left_join(monthly_crashes, by = "month") %>%
left_join(monthly_fatalities, by = "month") %>%
mutate(
total_crashes = replace_na(total_crashes, 0),
total_fatalities = replace_na(total_fatalities, 0)
) %>%
arrange(month)
# -------------------------
# MOVING AVERAGE FUNCTION
# -------------------------
add_ma <- function(df, var, k) {
out <- df
for (i in 1:k) {
out[[paste0(var, "_lag", i)]]  <- dplyr::lag(out[[var]], i)
out[[paste0(var, "_lead", i)]] <- dplyr::lead(out[[var]], i)
}
cols <- c(
paste0(var, "_lag", k:1),
var,
paste0(var, "_lead", 1:k)
)
out[[paste0(var, "_ma", k)]] <- rowMeans(out[, cols], na.rm = TRUE)
out
}
# -------------------------
# APPLY MAs
# -------------------------
df <- df %>%
add_ma("total_crashes", k = 3) %>%
add_ma("total_crashes", k = 6) %>%
add_ma("total_fatalities", k = 3) %>%
add_ma("total_fatalities", k = 6)
# -------------------------
# FINAL CLEAN OUTPUT
# -------------------------
final_df <- df %>%
select(
month,
total_crashes,
total_crashes_ma3,
total_crashes_ma6,
total_fatalities,
total_fatalities_ma3,
total_fatalities_ma6
)
final_df
View(df)
rm(list = ls())
suppressMessages(library(dplyr))
suppressMessages(library(lubridate))
suppressMessages(library(tidyr))
suppressMessages(library(readr))
# Load + clean
data <- read.csv("C:/Users/Matt/Documents/data/ep_data_(01-01-2016_05-02-2026).csv", header = TRUE)
data <- data %>%
mutate(
City = recode(City, "EL PASO" = "El Paso"),
Crash.Date = mdy(Crash.Date)
) %>%
filter(!(year(Crash.Date) == year(Sys.Date()) &
month(Crash.Date) == month(Sys.Date())))
# Levels
crash_level <- data %>%
distinct(Crash.ID, .keep_all = TRUE)
fatal_person_level <- data %>%
filter(Person.Injury.Severity == "K - FATAL INJURY")
# Monthly totals
monthly_crashes <- crash_level %>%
mutate(month = floor_date(Crash.Date, "month")) %>%
filter(month >= as.Date("2021-01-01"),
month <= as.Date("2025-07-31")) %>%
group_by(month) %>%
summarise(total_crashes = n(), .groups = "drop")
monthly_fatalities <- fatal_person_level %>%
mutate(month = floor_date(Crash.Date, "month")) %>%
filter(month >= as.Date("2021-01-01"),
month <= as.Date("2025-07-31")) %>%
group_by(month) %>%
summarise(total_fatalities = n(), .groups = "drop")
# Full month grid + merge
df <- tibble(
month = seq.Date(as.Date("2021-01-01"),
as.Date("2025-07-01"),
by = "month")
) %>%
left_join(monthly_crashes, by = "month") %>%
left_join(monthly_fatalities, by = "month") %>%
mutate(
total_crashes = replace_na(total_crashes, 0),
total_fatalities = replace_na(total_fatalities, 0)
) %>%
arrange(month)
# Moving averages (centered)
df <- df %>%
mutate(
total_crashes_ma3 = rowMeans(cbind(lag(total_crashes,3), lag(total_crashes,2), lag(total_crashes,1),
total_crashes,
lead(total_crashes,1), lead(total_crashes,2), lead(total_crashes,3)), na.rm = TRUE),
total_crashes_ma6 = rowMeans(cbind(lag(total_crashes,6), lag(total_crashes,5), lag(total_crashes,4),
lag(total_crashes,3), lag(total_crashes,2), lag(total_crashes,1),
total_crashes,
lead(total_crashes,1), lead(total_crashes,2), lead(total_crashes,3),
lead(total_crashes,4), lead(total_crashes,5), lead(total_crashes,6)), na.rm = TRUE),
total_fatalities_ma3 = rowMeans(cbind(lag(total_fatalities,3), lag(total_fatalities,2), lag(total_fatalities,1),
total_fatalities,
lead(total_fatalities,1), lead(total_fatalities,2), lead(total_fatalities,3)), na.rm = TRUE),
total_fatalities_ma6 = rowMeans(cbind(lag(total_fatalities,6), lag(total_fatalities,5), lag(total_fatalities,4),
lag(total_fatalities,3), lag(total_fatalities,2), lag(total_fatalities,1),
total_fatalities,
lead(total_fatalities,1), lead(total_fatalities,2), lead(total_fatalities,3),
lead(total_fatalities,4), lead(total_fatalities,5), lead(total_fatalities,6)), na.rm = TRUE)
)
# Final output
final_df <- df %>%
select(
month,
total_crashes,
total_crashes_ma3,
total_crashes_ma6,
total_fatalities,
total_fatalities_ma3,
total_fatalities_ma6
)
final_df
View(df)
