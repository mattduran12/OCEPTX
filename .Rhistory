list(
text = "Source: TXDOT CRIS Query Tool | Figure created by El Paso Crime Lab",
x = 0,
y = 0.02,   # inside plot area, bottom-left
xref = "paper",
yref = "paper",
xanchor = "left",
yanchor = "bottom",
showarrow = FALSE,
font = list(size = 9, color = "#6c757d")
)
),
margin = list(b = 90)  # consistent space for ALL charts
)
}
