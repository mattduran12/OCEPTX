library(tidyverse)
library(dplyr)
library(ggplot2)
library(patchwork)
ep.df <- read.csv("C:/Users/Matt/ASU Dropbox/Matthew Duran/Manuscripts & Projects/DWI Intervention/Submission materials/us-tx-ep-rates.csv")
data <- data.frame(
USA_alc = c((ep.df$usa_alc_fatal)),
Texas_alc = c(ep.df$tx_alc_fatal),
ElPaso_alc = ep.df$ep_alc_fatal,
USA_murder= c((ep.df$us_murder)),
Texas_murder = c(ep.df$tx_murder),
ElPaso_murder = ep.df$ep_murder,
Date = ep.df$year
)
theme_set(theme_bw(base_family = "Times New Roman"))
usa <- ggplot(data, aes(x = Date)) +
geom_line(aes(y = USA_murder, colour = "Homicide"), size = 0.8) +
geom_line(aes(y = USA_alc, colour = "Alcohol-related traffic fatality"), size = 0.8) +
ggtitle("United States") +
ylab("Deaths per 100,000 people") +
xlab("") +
scale_y_continuous(limits = c(0, 10), breaks = seq(0, 10, by = 1)) +
scale_x_continuous(breaks = seq(min(data$Date), max(data$Date), by = 5)) +
scale_colour_manual(
values = c(
"Homicide" = "#9c3f2b",
"Alcohol-related traffic fatality" = "black"
),
breaks = c("Homicide", "Alcohol-related traffic fatality"),
name = ""
) +
theme_bw() +
theme(
plot.title = element_text(size = 20, hjust = 0.5),
legend.position = "top",
legend.direction = "vertical",
legend.text = element_text(size = 20),
legend.key.size = unit(1.5, "lines"),
axis.text.x = element_text(angle = -90, hjust = 0, size = 18),
axis.text.y = element_text(size = 14),
axis.title.y = element_text(size = 18, margin = margin(r = 10))
)
tx <- ggplot(data, aes(x = Date)) +
geom_line(aes(y = Texas_murder, colour = "Homicide"), size = 0.8) +
geom_line(aes(y = Texas_alc, colour = "Alcohol-related traffic fatality"), size = 0.8) +
ggtitle("Texas") +
ylab("") +
xlab("") +
scale_y_continuous(limits = c(0, 10), breaks = seq(0, 10, by = 1)) +
scale_x_continuous(breaks = seq(min(data$Date), max(data$Date), by = 5)) +
scale_colour_manual(
values = c(
"Homicide" = "#9c3f2b",
"Alcohol-related traffic fatality" = "black"
),
breaks = c("Homicide", "Alcohol-related traffic fatality"),
name = ""
) +
theme_bw() +
theme(
plot.title = element_text(size = 20, hjust = 0.5),
legend.position = "top",
legend.direction = "vertical",
legend.text = element_text(size = 20),
legend.key.size = unit(1.5, "lines"),
axis.text.x = element_text(angle = -90, hjust = 0, size = 18),
axis.text.y = element_text(size = 14),
axis.title.y = element_text(size = 18, margin = margin(r = 10))
)
ep <- ggplot(data, aes(x = Date)) +
geom_line(aes(y = ElPaso_murder, colour = "Homicide"), size = 0.8) +
geom_line(aes(y = ElPaso_alc, colour = "Alcohol-related traffic fatality"), size = 0.8) +
ggtitle("El Paso") +
ylab("") +
xlab("") +
scale_y_continuous(limits = c(0, 10), breaks = seq(0, 10, by = 1)) +
scale_x_continuous(breaks = seq(min(data$Date), max(data$Date), by = 5)) +
scale_colour_manual(
values = c(
"Homicide" = "#9c3f2b",
"Alcohol-related traffic fatality" = "black"
),
breaks = c("Homicide", "Alcohol-related traffic fatality"),
name = ""
) +
theme_bw() +
theme(
plot.title = element_text(size = 20, hjust = 0.5),
legend.position = "top",
legend.direction = "vertical",
legend.text = element_text(size = 20),
legend.key.size = unit(1.5, "lines"),
axis.text.x = element_text(angle = -90, hjust = 0, size = 18),
axis.text.y = element_text(size = 14),
axis.title.y = element_text(size = 18, margin = margin(r = 10))
)
combined_plot <- (usa + tx + ep) +
plot_layout(nrow = 1, guides = "collect") &
theme(
legend.position = "bottom",
text = element_text(family = "Times New Roman"),
panel.background = element_rect(fill = "#fdf3e7", colour = NA),
plot.background  = element_rect(fill = "#fdf3e7", colour = NA),
legend.background = element_rect(fill = "#fdf3e7", colour = NA),
legend.key        = element_rect(fill = "#fdf3e7")
)
combined_plot
install.packages(c("DeclareDesign", "rdss"))
library(DeclareDesign)
library(tidyverse)
library(rdss)
## Cluster random sampling
design <- model +
declare_sampling(S = cluster_rs(clusters = villages,
n = 15))
library(DeclareDesign)
library(tidyverse)
library(rdss)
# Set up population to sample from
model <- declare_model(
villages = add_level(
N = 30,
N_households = sample(c(50:100), N, replace = TRUE)
),
households = add_level(
N = N_households,
N_members = sample(c(1, 2, 3, 4), N,
prob = c(0.2, 0.3, 0.25, 0.25), replace = TRUE)
),
individuals = add_level(
N = N_members,
age = sample(18:90, N, replace = TRUE),
gender = rbinom(n = N, size = 1, prob = .5)
)
)
# Sampling procedures
## Complete random sampling
design <- model +
declare_sampling(S = complete_rs(N = N, n = 1000))
head(draw_data(design))
## Cluster random sampling
design <- model +
declare_sampling(S = cluster_rs(clusters = villages,
n = 15))
head(draw_data(design))
## Strata and cluster random sampling
design <- model +
declare_sampling(S  = strata_and_cluster_rs(
strata = villages,
clusters = households,
strata_n = rep(20, 30)))
head(draw_data(design))
## Stratified random sampling
design <- model +
declare_sampling(S = strata_rs(strata = gender, n = 100))
head(draw_data(design))
ICC <- 0.4
two_nigerian_states <-
fabricate(
state = add_level(N = 2,
state_name = c("taraba", "kwara"),
state_mean = c(-0.2, 0.2)),
locality = add_level(
N = 500,
locality_shock = rnorm(N, state_mean, sqrt(ICC))
),
individual = add_level(
N = 100,
individual_shock = rnorm(N, sd = sqrt(1 - ICC)),
Y_star = locality_shock + individual_shock
)
)
budget_function <-
function(cluster_prob){
budget = 20000
cluster_cost = 20
individual_cost = 2
n_clusters = 1000
n_individuals_per_cluster = 100
total_cluster_cost <-
cluster_prob * n_clusters * cluster_cost
remaining_funds <- budget - total_cluster_cost
sampleable_individuals <-
cluster_prob * n_clusters * n_individuals_per_cluster
individual_prob =
(remaining_funds/individual_cost)/sampleable_individuals
pmin(individual_prob, 1)
}
budget_function
budget_function(0.05)
budget_function(0.05)
budget_function(0.25)
budget_function(0.50)
cluster_probs <- seq(0.01, 1, by = 0.01)
results <- data.frame(
cluster_prob = cluster_probs,
individual_prob = budget_function(cluster_probs)
)
plot(
results$cluster_prob,
results$individual_prob,
type = "l",
xlab = "Cluster sampling probability",
ylab = "Individual sampling probability",
main = "Budget constraint: cluster vs individual sampling"
)
