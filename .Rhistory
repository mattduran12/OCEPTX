labels = ~labels,
parents = ~parents,
values = ~value,
branchvalues = "total",
marker = list(colors = nodes$color),
insidetextorientation = "radial",
hovertemplate = paste0(
"<b>%{label}</b><br>",
"Count: %{value}<extra></extra>"
)
) %>%
layout(
title = list(
text = paste0(
"<b>Alcohol-Related Crash Outcomes</b><br>",
"<sup>April 2026 | El Paso, Texas</sup>"
),
x = 0.5
),
margin = list(l = 10, r = 10, t = 80, b = 60)
)
# -----------------------------
# TIME WINDOW
# -----------------------------
report_date  <- Sys.Date() %m-% months(1)
report_year  <- year(report_date)
report_month <- month(report_date)
# -----------------------------
# CRASH LEVEL
# -----------------------------
crash_info <- crash_level %>%
mutate(date = as.Date(Crash.Date)) %>%
filter(
City == "El Paso",
Crash.Year == report_year,
month(date) == report_month
) %>%
distinct(Crash.ID, .keep_all = TRUE) %>%
mutate(
crash_type = if_else(Fatal.Crash.Flag == 1,
"Fatal crash",
"Non-fatal crash")
) %>%
select(Crash.ID, crash_type)
crash_ids <- unique(crash_info$Crash.ID)
# -----------------------------
# DRIVER LEVEL
# -----------------------------
driver_info <- person_level %>%
mutate(
date = as.Date(Crash.Date),
driver_flag = Person.Type %in% c(
"1 - DRIVER",
"5 - DRIVER OF MOTORCYCLE TYPE VEHICLE"
),
bac_value = suppressWarnings(
as.numeric(Person.Blood.Alcohol.Content.Test.Result)
),
driver_type = if_else(
driver_flag & !is.na(bac_value) & bac_value >= 0.08,
"Intoxicated driver",
"Non-intoxicated driver"
)
) %>%
filter(
Crash.ID %in% crash_ids,
driver_flag
) %>%
distinct(Crash.ID, .keep_all = TRUE) %>%
select(Crash.ID, driver_type)
# -----------------------------
# INJURY LEVEL
# -----------------------------
injury_info <- person_level %>%
filter(Crash.ID %in% crash_ids) %>%
mutate(
injury_type = case_when(
Person.Injury.Severity == "K - FATAL INJURY" ~ "Fatal injury",
Person.Injury.Severity == "A - SUSPECTED SERIOUS INJURY" ~ "Serious injury",
Person.Injury.Severity == "B - SUSPECTED MINOR INJURY" ~ "Minor injury",
Person.Injury.Severity == "C - POSSIBLE INJURY" ~ "Possible injury",
Person.Injury.Severity == "N - NOT INJURED" ~ "Not injured",
TRUE ~ NA_character_
)
) %>%
filter(!is.na(injury_type)) %>%
select(Crash.ID, injury_type)
# -----------------------------
# MERGE
# -----------------------------
df <- crash_info %>%
left_join(driver_info, by = "Crash.ID") %>%
left_join(injury_info, by = "Crash.ID") %>%
mutate(
driver_type = if_else(is.na(driver_type),
"Non-intoxicated driver",
driver_type),
injury_type = if_else(is.na(injury_type),
"Not injured",
injury_type)
)
# -----------------------------
# SAFE AGGREGATION (KEY FIX)
# -----------------------------
lvl1 <- df %>%
count(crash_type, name = "value") %>%
transmute(
ids = crash_type,
labels = crash_type,
parents = "All crashes",
value
)
lvl2 <- df %>%
count(crash_type, driver_type, name = "value") %>%
transmute(
ids = paste(crash_type, driver_type),
labels = driver_type,
parents = crash_type,
value
)
lvl3 <- df %>%
count(crash_type, driver_type, injury_type, name = "value") %>%
transmute(
ids = paste(crash_type, driver_type, injury_type),
labels = injury_type,
parents = paste(crash_type, driver_type),
value
)
root <- tibble(
ids = "All crashes",
labels = "All crashes",
parents = "",
value = sum(lvl1$value)
)
nodes <- bind_rows(root, lvl1, lvl2, lvl3)
# -----------------------------
# COLORS
# -----------------------------
nodes$color <- case_when(
nodes$labels == "Fatal crash" ~ "maroon",
nodes$labels == "Non-fatal crash" ~ "steelblue",
nodes$labels == "Intoxicated driver" ~ "gray60",
nodes$labels == "Non-intoxicated driver" ~ "gray75",
nodes$labels == "Fatal injury" ~ "maroon",
nodes$labels %in% c("Serious injury","Minor injury","Possible injury") ~ "darkorange",
nodes$labels == "Not injured" ~ "gray70",
TRUE ~ "gray85"
)
# -----------------------------
# FINAL PLOT
# -----------------------------
plot_ly(
data = nodes,
type = "sunburst",
ids = ~ids,
labels = ~labels,
parents = ~parents,
values = ~value,
branchvalues = "total",
marker = list(colors = nodes$color),
insidetextorientation = "radial",
hovertemplate = "<b>%{label}</b><br>Count: %{value}<extra></extra>"
) %>%
layout(
title = list(
text = paste0(
"<b>Alcohol-Related Crash Outcomes</b><br>",
"<sup>", format(report_date, "%B %Y"), " | El Paso, Texas</sup>"
),
x = 0.5
),
margin = list(l = 10, r = 10, t = 80, b = 60)
)
# -----------------------------
# TIME WINDOW
# -----------------------------
report_date  <- Sys.Date() %m-% months(1)
report_year  <- year(report_date)
report_month <- month(report_date)
# ------------------------------------------------
# CRASH-LEVEL (ONE ROW PER CRASH)
# ------------------------------------------------
crash_info <- crash_level %>%
mutate(date = as.Date(Crash.Date)) %>%
filter(
City == "El Paso",
Crash.Year == report_year,
month(date) == report_month
) %>%
distinct(Crash.ID, .keep_all = TRUE) %>%
mutate(
crash_type = if_else(Fatal.Crash.Flag == 1,
"Fatal crash",
"Non-fatal crash")
) %>%
select(Crash.ID, crash_type)
# ------------------------------------------------
# DRIVER-LEVEL → COLLAPSE TO CRASH LEVEL
# (fixes inflation problem)
# ------------------------------------------------
driver_info <- person_level %>%
mutate(
date = as.Date(Crash.Date),
driver_flag = Person.Type %in% c(
"1 - DRIVER",
"5 - DRIVER OF MOTORCYCLE TYPE VEHICLE"
),
bac_value = suppressWarnings(
as.numeric(Person.Blood.Alcohol.Content.Test.Result)
),
intox = driver_flag & !is.na(bac_value) & bac_value >= 0.08
) %>%
filter(
City == "El Paso",
Crash.Year == report_year,
month(date) == report_month,
driver_flag
) %>%
group_by(Crash.ID) %>%
summarise(
driver_type = if_else(any(intox),
"Intoxicated driver",
"Non-intoxicated driver"),
.groups = "drop"
)
# ------------------------------------------------
# INJURY-LEVEL → COLLAPSE TO CRASH LEVEL
# (take worst injury per crash)
# ------------------------------------------------
injury_rank <- c(
"Not injured" = 1,
"Possible injury" = 2,
"Minor injury" = 3,
"Serious injury" = 4,
"Fatal injury" = 5
)
injury_info <- person_level %>%
mutate(date = as.Date(Crash.Date)) %>%
filter(
City == "El Paso",
Crash.Year == report_year,
month(date) == report_month
) %>%
mutate(
injury_type = case_when(
Person.Injury.Severity == "K - FATAL INJURY" ~ "Fatal injury",
Person.Injury.Severity == "A - SUSPECTED SERIOUS INJURY" ~ "Serious injury",
Person.Injury.Severity == "B - SUSPECTED MINOR INJURY" ~ "Minor injury",
Person.Injury.Severity == "C - POSSIBLE INJURY" ~ "Possible injury",
Person.Injury.Severity == "N - NOT INJURED" ~ "Not injured",
TRUE ~ NA_character_
),
rank = injury_rank[injury_type]
) %>%
filter(!is.na(injury_type)) %>%
group_by(Crash.ID) %>%
summarise(
injury_type = injury_type[which.max(rank)],
.groups = "drop"
)
# ------------------------------------------------
# FINAL MERGED DATA (NOW TRUE CRASH-LEVEL)
# ------------------------------------------------
df <- crash_info %>%
left_join(driver_info, by = "Crash.ID") %>%
left_join(injury_info, by = "Crash.ID") %>%
mutate(
driver_type = if_else(is.na(driver_type),
"Non-intoxicated driver",
driver_type),
injury_type = if_else(is.na(injury_type),
"Not injured",
injury_type)
)
# ------------------------------------------------
# AGGREGATE NODES
# ------------------------------------------------
lvl1 <- df %>%
count(crash_type, name = "value") %>%
mutate(
ids = crash_type,
labels = crash_type,
parents = "All crashes"
)
lvl2 <- df %>%
count(crash_type, driver_type, name = "value") %>%
mutate(
ids = paste(crash_type, driver_type),
labels = driver_type,
parents = crash_type
)
lvl3 <- df %>%
count(crash_type, driver_type, injury_type, name = "value") %>%
mutate(
ids = paste(crash_type, driver_type, injury_type),
labels = injury_type,
parents = paste(crash_type, driver_type)
)
root <- data.frame(
ids = "All crashes",
labels = "All crashes",
parents = "",
value = n_distinct(df$Crash.ID)
)
nodes <- bind_rows(root, lvl1, lvl2, lvl3)
# ------------------------------------------------
# COLORS
# ------------------------------------------------
nodes$color <- case_when(
nodes$labels == "Fatal crash" ~ "maroon",
nodes$labels == "Non-fatal crash" ~ "steelblue",
nodes$labels == "Intoxicated driver" ~ "gray60",
nodes$labels == "Non-intoxicated driver" ~ "gray75",
nodes$labels == "Fatal injury" ~ "maroon",
nodes$labels %in% c("Serious injury","Minor injury","Possible injury") ~ "darkorange",
nodes$labels == "Not injured" ~ "gray70",
TRUE ~ "gray85"
)
# ------------------------------------------------
# SUNBURST PLOT
# ------------------------------------------------
plot_ly(
data = nodes,
type = "sunburst",
ids = ~ids,
labels = ~labels,
parents = ~parents,
values = ~value,
branchvalues = "total",
marker = list(colors = nodes$color),
insidetextorientation = "radial",
hovertemplate = paste0(
"<b>%{label}</b><br>",
"Crashes: %{value}<extra></extra>"
)
) %>%
layout(
title = list(
text = paste0(
"<b>Alcohol-Related Crash Outcomes</b><br>",
"<sup>", format(report_date, "%B %Y"), " | El Paso, Texas</sup>"
),
x = 0.5
),
margin = list(l = 10, r = 10, t = 80, b = 60),
annotations = list(
list(
x = 0, y = -0.08,
xref = "paper", yref = "paper",
xanchor = "left",
yanchor = "top",
text = "Data source: Texas Department of Transportation | Created by El Paso Crime Lab",
showarrow = FALSE,
font = list(size = 10, color = "gray50")
)
)
)
# -----------------------------
# TIME WINDOW
# -----------------------------
report_date  <- Sys.Date() %m-% months(1)
report_year  <- year(report_date)
report_month <- month(report_date)
# CRASH LEVEL
# -----------------------------
crash_info <- crash_level %>%
mutate(date = as.Date(Crash.Date)) %>%
filter(
City == "El Paso",
Crash.Year == report_year,
month(date) == report_month
) %>%
distinct(Crash.ID, .keep_all = TRUE) %>%
mutate(
crash_type = if_else(Fatal.Crash.Flag == 1,
"Fatal crash",
"Non-fatal crash")
) %>%
select(Crash.ID, crash_type)
# -----------------------------
# DRIVER TYPE (CRASH-LEVEL COLLAPSED)
# -----------------------------
driver_info <- person_level %>%
mutate(
date = as.Date(Crash.Date),
driver_flag = Person.Type %in% c(
"1 - DRIVER",
"5 - DRIVER OF MOTORCYCLE TYPE VEHICLE"
),
bac_value = suppressWarnings(
as.numeric(Person.Blood.Alcohol.Content.Test.Result)
),
intox = driver_flag & !is.na(bac_value) & bac_value >= 0.08
) %>%
filter(
City == "El Paso",
Crash.Year == report_year,
month(date) == report_month,
driver_flag
) %>%
group_by(Crash.ID) %>%
summarise(
driver_type = if_else(any(intox),
"Intoxicated drivers present",
"No intoxicated drivers"),
.groups = "drop"
)
# -----------------------------
# INJURY TYPE (CRASH-LEVEL COLLAPSED)
# -----------------------------
injury_rank <- c(
"Not injured" = 1,
"Possible injury" = 2,
"Minor injury" = 3,
"Serious injury" = 4,
"Fatal injury" = 5
)
injury_info <- person_level %>%
mutate(date = as.Date(Crash.Date)) %>%
filter(
City == "El Paso",
Crash.Year == report_year,
month(date) == report_month
) %>%
mutate(
injury_type = case_when(
Person.Injury.Severity == "K - FATAL INJURY" ~ "Fatal injury",
Person.Injury.Severity == "A - SUSPECTED SERIOUS INJURY" ~ "Serious injury",
Person.Injury.Severity == "B - SUSPECTED MINOR INJURY" ~ "Minor injury",
Person.Injury.Severity == "C - POSSIBLE INJURY" ~ "Possible injury",
Person.Injury.Severity == "N - NOT INJURED" ~ "Not injured",
TRUE ~ NA_character_
),
rank = injury_rank[injury_type]
) %>%
filter(!is.na(injury_type)) %>%
group_by(Crash.ID) %>%
summarise(
injury_type = injury_type[which.max(rank)],
.groups = "drop"
)
# -----------------------------
# FINAL CRASH-LEVEL TABLE (NO DUPLICATION)
# -----------------------------
df <- crash_info %>%
left_join(driver_info, by = "Crash.ID") %>%
left_join(injury_info, by = "Crash.ID") %>%
mutate(
driver_type = if_else(is.na(driver_type),
"No intoxicated drivers",
driver_type),
injury_type = if_else(is.na(injury_type),
"Not injured",
injury_type)
)
# -----------------------------
# FLOW 1: CRASH → DRIVER TYPE
# -----------------------------
links1 <- df %>%
count(crash_type, driver_type, name = "value") %>%
rename(source = crash_type, target = driver_type)
# -----------------------------
# FLOW 2: CRASH → INJURY TYPE
# -----------------------------
links2 <- df %>%
count(crash_type, injury_type, name = "value") %>%
rename(source = crash_type, target = injury_type)
# -----------------------------
# COMBINE LINKS
# -----------------------------
links <- bind_rows(links1, links2)
nodes <- data.frame(name = unique(c(links$source, links$target)))
nodes$color <- case_when(
nodes$name == "Fatal crash" ~ "maroon",
nodes$name == "Non-fatal crash" ~ "steelblue",
nodes$name == "Intoxicated drivers present" ~ "gray60",
nodes$name == "No intoxicated drivers" ~ "gray75",
nodes$name == "Fatal injury" ~ "maroon",
nodes$name %in% c("Serious injury","Minor injury","Possible injury") ~ "darkorange",
nodes$name == "Not injured" ~ "gray70",
TRUE ~ "gray85"
)
links$source_id <- match(links$source, nodes$name) - 1
links$target_id <- match(links$target, nodes$name) - 1
# -----------------------------
# PLOTLY SANKEY (CORRECT STRUCTURE)
# -----------------------------
plot_ly(
type = "sankey",
arrangement = "snap",
node = list(
label = nodes$name,
color = nodes$color,
pad = 20,
thickness = 18
),
link = list(
source = links$source_id,
target = links$target_id,
value = links$value
)
) %>%
layout(
title = list(
text = paste0(
"<b>Alcohol-Related Crash Outcomes (April 2026)</b>",
"<br><sup>El Paso, Texas</sup>"
),
x = 0.5
),
margin = list(l = 10, r = 10, t = 80, b = 60)
)
