group_by(year, days_from_cinco) %>%
summarise(n = n(), .groups = "drop") %>%
group_by(days_from_cinco) %>%
summarise(avg_crashes = mean(n), .groups = "drop") %>%
mutate(is_cinco = ifelse(days_from_cinco == 0, "Cinco de Mayo", "Other Days"))
# Highlight Cinco de Mayo point
plot_data <- plot_data %>%
mutate(is_cinco = ifelse(days_from_cinco == 0, "Cinco de Mayo", "Other Days"))
p <- ggplot(plot_data, aes(x = days_from_cinco, y = avg_crashes)) +
# Shaded window (days 1–3)
geom_rect(
xmin = 1, xmax = 3,
ymin = -Inf, ymax = Inf,
fill = "red",
alpha = 0.08
) +
geom_smooth(se = FALSE, method = "loess", span = 0.3,
color = "#2C3E50", size = 1) +
geom_point(aes(color = is_cinco), size = 3) +
geom_vline(xintercept = 0, linetype = "dashed",
