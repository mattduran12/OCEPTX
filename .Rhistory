#| title: Crash Locations (YTD)
top_streets <- crash_level %>%
filter(
City == "El Paso",
Crash.Year == 2026
) %>%
count(Street.Name, sort = TRUE) %>%
mutate(
percent = round(n / sum(n) * 100, 2)
) %>%
rename(
"Street Name" = Street.Name,
"Crash Count" = n,
"Percent (%)" = percent
)
reactable(
top_streets,
# Pagination
defaultPageSize = 15,
# Styling
striped = TRUE,
highlight = TRUE,
# Search + sort (nice for long street lists)
searchable = TRUE,
defaultSorted = list(`Crash Count` = "desc"),
# Column formatting
columns = list(
`Street Name` = colDef(minWidth = 200),
`Crash Count` = colDef(align = "center"),
`Percent (%)` = colDef(
format = colFormat(digits = 2),
align = "center"
)
),
# Clean look
compact = TRUE,
bordered = FALSE
)
