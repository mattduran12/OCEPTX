subtitle = "Average BAC and Age by Ethnicity and Gender"
) %>%
# Clean column labels (optional reinforcement)
cols_label(
Ethnicity = "Ethnicity",
Gender = "Gender",
`Average BAC` = "Avg BAC",
`Average Age` = "Avg Age",
Count = "N"
) %>%
# Number formatting
fmt_number(
columns = c(`Average BAC`),
decimals = 3
) %>%
fmt_number(
columns = c(`Average Age`),
decimals = 1
) %>%
# Alignments
cols_align(
align = "center",
columns = everything()
) %>%
# Simple clean theme
tab_options(
table.font.size = "small",
heading.title.font.size = "medium",
heading.subtitle.font.size = "small",
table.border.top.style = "none",
table.border.bottom.style = "solid",
column_labels.border.bottom.style = "solid"
)
