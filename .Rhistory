# You need to figure out how to limit the resutls to crashes that were alcohol-related
data <- read.csv("C:/Users/Matt/Documents/data/ep_data_(01-01-2016_05-02-2026).csv", header = TRUE)
data$City <- recode(data$City,
"EL PASO" = "El Paso"
)
# drop current month, since its incomplete
data <- data %>%
mutate(
Crash.Date = mdy(Crash.Date)
) %>%
filter(
!(year(Crash.Date) == year(Sys.Date()) &
month(Crash.Date) == month(Sys.Date()))
)
person_level <- data
vehicle_level <- data %>%
distinct(Crash.ID, Unit.Number, .keep_all = TRUE)
crash_level <- data %>%
distinct(Crash.ID, .keep_all = TRUE)
# Crashes
monthly_counts_crash <- crash_level %>%   # or crash_level if not filtering
mutate(
month = floor_date(Crash.Date, "month")
) %>%
filter(
month >= as.Date("2021-01-01") &
month <= as.Date("2025-07-31")
) %>%
group_by(month) %>%
summarise(
total_crashes = n(),
.groups = "drop"
) %>%
arrange(month)
# Fatalities
monthly_counts_person <- person_level %>%   # or crash_level if not filtering
mutate(
month = floor_date(Crash.Date, "month")
) %>%
filter(
month >= as.Date("2021-01-01") &
month <= as.Date("2025-07-31")
) %>%
group_by(month) %>%
summarise(
total_crashes = n(),
.groups = "drop"
) %>%
arrange(month)
View(monthly_counts_person)
rm(list = ls())
