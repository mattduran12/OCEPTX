padding: 14px;
margin-bottom: 12px;
border: 1px solid #e5e7eb;
border-radius: 10px;
background-color: #ffffff;
'>",
"<a href='", rss_items$item_link[i], "' target='_blank' style='
font-weight: 600;
font-size: 1.05em;
color: #1a1a1a;
text-decoration: none;
'>",
rss_items$item_title[i],
"</a>",
"<div style='
margin-top: 6px;
color: #6b7280;
font-size: 0.85em;
'>",
rss_items$item_pub_date[i],
"</div>",
"</div>"
)
)
}
