source("~/data/steps for combining and tagging data as alcohol-related.R")
# update this file path with the new month of data AND the filepath on line 74
combined_df <- read.csv("C:/Users/Matt/Documents/data/ep_data_(01-01-2016_05-12-2026).csv",  header = TRUE)
library(dplyr)
# String to tag ***at the person-level ** alcohol-involved crashes (matches with TxDot filter 5-3-2026)
df <- combined_df %>%
mutate(
alc_related = if_else(
if_any(
c(
Contributing.Factor.1,
Contributing.Factor.2,
Contributing.Factor.3,
Possible.Contributing.Factor.1,
Possible.Contributing.Factor.2
),
~ . %in% c(
"67 - INTOXICATED - ALCOHOL",
"45 - HAD BEEN DRINKING"
)
)
|
(
!is.na(Person.Blood.Alcohol.Content.Test.Result) &
!Person.Blood.Alcohol.Content.Test.Result %in% c("No Data", "0")
),
1,
0
)
)
# Tag all crashes that were alc-related
df <- df %>%
group_by(Crash.ID) %>%
mutate(
crash_alc_related = as.integer(any(alc_related == 1, na.rm = TRUE))
) %>%
ungroup()
# Filter data
df <- df %>% filter(df$crash_alc_related==1)
# Export data
write.csv(
df,
"C:/Users/Matt/Documents/data/ep_data_(01-01-2016_05-12-2026)_2.csv",
row.names = FALSE
)
