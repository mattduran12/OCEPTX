#| title: Intoxicated Driver's License Zipcode (YTD)
zip_top10 <- drivers %>%
filter(bac_value >= 0.08 & bac_result == 1,
!is.na(Driver.Zip.Code)) %>%
group_by(Driver.Zip.Code) %>%
summarise(n = n(), .groups = "drop") %>%
arrange(desc(n)) %>%
slice_head(n = 10)
# drivers object with BACs only
drivers <- person_level %>%
mutate(
driver_flag = case_when(
Person.Type %in% c(
"1 - DRIVER",
"5 - DRIVER OF MOTORCYCLE TYPE VEHICLE"
) ~ 1,
TRUE ~ 0
),
bac_value = as.numeric(Person.Blood.Alcohol.Content.Test.Result),
bac_result = case_when(
!is.na(bac_value) & bac_value > 0 ~ 1,
TRUE ~ 0
)
) %>%
filter(
City == "El Paso",
Crash.Year == 2026,
driver_flag == 1,
)
# drivers object with BACs only
drivers <- person_level %>%
mutate(
driver_flag = case_when(
Person.Type %in% c(
"1 - DRIVER",
"5 - DRIVER OF MOTORCYCLE TYPE VEHICLE"
) ~ 1,
TRUE ~ 0
),
bac_value = as.numeric(Person.Blood.Alcohol.Content.Test.Result),
bac_result = case_when(
!is.na(bac_value) & bac_value > 0 ~ 1,
TRUE ~ 0
)
) %>%
filter(
City == "El Paso",
Crash.Year == 2026,
driver_flag == 1,
)
#| title: Intoxicated Driver's License Zipcode (YTD)
zip_top10 <- drivers %>%
filter(bac_value >= 0.08 & bac_result == 1,
!is.na(Driver.Zip.Code)) %>%
group_by(Driver.Zip.Code) %>%
summarise(n = n(), .groups = "drop") %>%
arrange(desc(n)) %>%
slice_head(n = 10)
zip_top10 <- zip_top10 %>%
mutate(
pct = n / sum(n),
label_full = paste0(Driver.Zip.Code, "\n", n, " (", scales::percent(pct), ")")
)
p <- plot_ly(
data = zip_top10,
type = "treemap",
labels = ~label_full,
parents = rep("", nrow(zip_top10)),
values = ~n,
textinfo = "label",
marker = list(
colors = rep("#f4b942", nrow(zip_top10))
),
hovertemplate = paste(
"ZIP: %{label}<br>",
"Drivers: %{value}<br>",
"<extra></extra>"
)
)
p %>%
layout(
title = list(
text = paste0(
"<b>Top 10 Zipcodes of Intoxicated Drivers (BAC ≥ 0.08)</b> <b>who Crashed in El Paso</b>", "<br><sup>Year-to-Date</sup>"
),
x = 0.5,
xanchor = "center"
),
# 🔥 THIS is what you’re missing
