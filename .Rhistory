subtitle = "Average BAC and Age by Ethnicity and Gender"
) %>%
# Zebra striping
opt_row_striping() %>%
# Make header row slightly bolder + cleaner
tab_style(
style = list(
cell_text(weight = "bold")
),
locations = cells_column_labels()
) %>%
