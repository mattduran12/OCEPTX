memorial_dates <- base %>%
distinct(year) %>%
mutate(
memorial_day = as.Date(paste0(year, "-05-31")) -
(wday(as.Date(paste0(year, "-05-31")), week_start = 1) - 1)
)
# ----------------------------
# Step 3: attach + compute event time
# ----------------------------
check <- base %>%
left_join(memorial_dates, by = "year") %>%
mutate(
days_from_memorial = as.numeric(date - memorial_day)
) %>%
group_by(year, memorial_day) %>%
summarise(
# THIS IS THE KEY CHECK:
actual_zero_day = sum(days_from_memorial == 0),
.groups = "drop"
)
