library(tidyRSS)
library(dplyr)
library(stringr)
# ----------------------------
# RSS SOURCES (EN + ES)
# ----------------------------
rss_url_en <- "https://news.google.com/rss/search?q=(\"DWI\" OR \"DUI\" OR \"drunk driving\" OR \"impaired driving\" OR \"drinking and driving\" OR \"drinking driver\" OR \"driver was drinking\" OR \"had been drinking\" OR \"alcohol-related crash\" OR \"alcohol related crash\" OR \"alcohol-involved crash\" OR \"alcohol involved crash\" OR \"alcohol-related accident\" OR \"drunk crash\" OR \"intoxicated\" OR \"suspected intoxicated driver\" OR \"under the influence\" OR \"driving under the influence\") \"El Paso\"&hl=en-US&gl=US&ceid=US:en"
rss_url_es <- "https://news.google.com/rss/search?q=(\"DUI\"%20OR%20\"DWI\"%20OR%20\"manejar%20ebrio\"%20OR%20\"conducir%20ebrio\"%20OR%20\"conducci%C3%B3n%20bajo%20influencia\")%20\"El%20Paso\"&hl=es-419&gl=US&ceid=US:es"
# ----------------------------
