library(tidyRSS)
library(dplyr)
library(lubridate)
rss_url <- "https://news.google.com/rss/search?q=(\"DWI\"%20OR%20\"drunk%20driving\"%20OR%20\"impaired%20driving\")%20\"El%20Paso\"&hl=en-US&gl=US&ceid=US:en"
rss_items <- tidyfeed(rss_url) %>%
select(item_title, item_link, item_pub_date) %>%
mutate(item_pub_date = ymd_hms(item_pub_date)) %>%
arrange(desc(item_pub_date)) %>%
slice_head(n = 10)
for (i in 1:nrow(rss_items)) {
cat(
paste0(
"<div style='margin-bottom: 1.2rem;'>",
"<a href='", rss_items$item_link[i], "' target='_blank'><strong>",
rss_items$item_title[i], "</strong></a><br>",
"<span style='color: gray; font-size: 0.9em;'>",
format(rss_items$item_pub_date[i], "%b %d, %Y"),
"</span>",
"</div>"
)
)
}
