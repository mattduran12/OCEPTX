)) +
scale_x_continuous(breaks = seq(-7, 7, by = 1)) +
labs(
title = "Do Crashes Increase Around Cinco de Mayo?",
x = "Days from May 5th",
y = "Average Number of Crashes"
) +
theme_minimal(base_size = 14) +
theme(
plot.title = element_text(size = 18),
legend.position = "none"
)
ggplotly(p)
#| title: ¡Cinco De Mayo!
crash_data <- crash_level %>%
filter(City == "El Paso",
Crash.Year != 2020) %>%
mutate(
date = as.Date(Crash.Date),
year = Crash.Year,
cinco = as.Date(paste0(year, "-05-05")),
days_from_cinco = as.numeric(date - cinco)
)
window_data <- crash_data %>%
filter(days_from_cinco >= -7 & days_from_cinco <= 7)
plot_data <- window_data %>%
group_by(year, days_from_cinco) %>%
summarise(n = n(), .groups = "drop") %>%
group_by(days_from_cinco) %>%
summarise(avg_crashes = mean(n), .groups = "drop") %>%
mutate(is_cinco = ifelse(days_from_cinco == 0, "Cinco de Mayo", "Other Days"))
# Highlight Cinco de Mayo point
plot_data <- plot_data %>%
mutate(is_cinco = ifelse(days_from_cinco == 0, "Cinco de Mayo", "Other Days"))
p <- ggplot(plot_data, aes(x = days_from_cinco, y = avg_crashes)) +
# Shaded window (days 1–3)
geom_rect(
xmin = 1, xmax = 3,
ymin = -Inf, ymax = Inf,
fill = "red",
alpha = 0.08
) +
geom_smooth(se = FALSE, method = "loess", span = 0.3,
color = "#2C3E50", size = 1) +
geom_point(aes(color = is_cinco), size = 3) +
geom_vline(xintercept = 0, linetype = "dashed",
color = "#C0392B", size = 1) +
scale_color_manual(values = c(
"Cinco de Mayo" = "#C0392B",
"Other Days" = "#34495E"
)) +
scale_x_continuous(breaks = seq(-7, 7, by = 1)) +
labs(
title = "Do Crashes Increase Around Cinco de Mayo?",
x = "Days from May 5th",
y = "Average Number of Crashes"
) +
theme_minimal(base_size = 14) +
theme(
plot.title = element_text(size = 18),
legend.position = "none"
)
ggplotly(p) %>%
layout(
shapes = list(
list(
type = "rect",
x0 = 1, x1 = 3,
y0 = 0, y1 = 1,
yref = "paper",
fillcolor = "red",
opacity = 0.08,
line = list(width = 0)
)
)
)
ggplotly(p)
ggplotly(p)
#| title: ¡Cinco De Mayo!
crash_data <- crash_level %>%
filter(City == "El Paso",
Crash.Year != 2020) %>%
mutate(
date = as.Date(Crash.Date),
year = Crash.Year,
cinco = as.Date(paste0(year, "-05-05")),
days_from_cinco = as.numeric(date - cinco)
)
window_data <- crash_data %>%
filter(days_from_cinco >= -7 & days_from_cinco <= 7)
plot_data <- window_data %>%
group_by(year, days_from_cinco) %>%
summarise(n = n(), .groups = "drop") %>%
group_by(days_from_cinco) %>%
summarise(avg_crashes = mean(n), .groups = "drop") %>%
mutate(is_cinco = ifelse(days_from_cinco == 0, "Cinco de Mayo", "Other Days"))
# Highlight Cinco de Mayo point
plot_data <- plot_data %>%
mutate(is_cinco = ifelse(days_from_cinco == 0, "Cinco de Mayo", "Other Days"))
plot_ly(
data = plot_data,
x = ~days_from_cinco,
y = ~avg_crashes,
type = "scatter",
mode = "lines+markers",
showlegend = FALSE,
marker = list(size = 8, color = "#34495E")
) %>%
add_markers(
data = subset(plot_data, is_cinco == "Cinco de Mayo"),
x = ~days_from_cinco,
y = ~avg_crashes,
marker = list(color = "#C0392B", size = 10),
showlegend = FALSE
) %>%
layout(
# 🔴 THIS is the working shaded rectangle
shapes = list(
list(
type = "rect",
x0 = 1, x1 = 3,
y0 = 0, y1 = 1,
yref = "paper",
fillcolor = "red",
opacity = 0.08,
line = list(width = 0)
)
),
title = "Do Crashes Increase Around Cinco de Mayo?",
xaxis = list(
title = "Days from May 5th",
dtick = 1
),
yaxis = list(
title = "Average Number of Crashes"
)
)
