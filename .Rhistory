data <- read.csv("C:/Users/Matt/Documents/data/ep_data_(01-01-2016_05-12-2026).csv", header = TRUE)
data$City <- recode(data$City,
"EL PASO" = "El Paso"
)
# drop current month, since its incomplete
data <- data %>%
mutate(
Crash.Date = mdy(Crash.Date)
) %>%
filter(
!(year(Crash.Date) == year(Sys.Date()) &
month(Crash.Date) == month(Sys.Date()))
)
person_level <- data
vehicle_level <- data %>%
distinct(Crash.ID, Unit.Number, .keep_all = TRUE)
crash_level <- data %>%
distinct(Crash.ID, .keep_all = TRUE)
# ----------------------------
# REPORTING MONTH (DATA LAGS 1 MONTH)
# ----------------------------
report_date <- Sys.Date() %m-% months(1)
report_month <- format(report_date, "%B %Y")
report_year <- year(report_date)
prev_year <- report_year - 1
# ----------------------------
# MONTHLY DATA
# ----------------------------
this_month <- crash_level %>%
filter(
City == "El Paso",
year(Crash.Date) == report_year,
month(Crash.Date) == month(report_date)
)
last_month <- crash_level %>%
filter(
City == "El Paso",
year(Crash.Date) == prev_year,
month(Crash.Date) == month(report_date)
)
# ----------------------------
# METRICS
# ----------------------------
crashes_now <- n_distinct(this_month$Crash.ID)
crashes_prev <- n_distinct(last_month$Crash.ID)
# ----------------------------
# INJURIES (MATCH YOUR CLEAN LOGIC)
# ----------------------------
injuries_now <- person_level %>%
filter(
City == "El Paso",
year(Crash.Date) == report_year,
month(Crash.Date) == month(report_date),
!Person.Injury.Severity %in% c(
"99 - UNKNOWN",
"95 - AUTONOMOUS",
"N - NOT INJURED",
"K - FATAL INJURY"
),
!is.na(Person.Injury.Severity)
) %>%
summarise(n = n()) %>%
pull(n)
injuries_prev <- person_level %>%
filter(
City == "El Paso",
year(Crash.Date) == prev_year,
month(Crash.Date) == month(report_date),
!Person.Injury.Severity %in% c(
"99 - UNKNOWN",
"95 - AUTONOMOUS",
"N - NOT INJURED",
"K - FATAL INJURY"
),
!is.na(Person.Injury.Severity)
) %>%
summarise(n = n()) %>%
pull(n)
# ----------------------------
# FATALITIES (KEEP CONSISTENT)
# ----------------------------
fatal_now <- person_level %>%
filter(
City == "El Paso",
year(Crash.Date) == report_year,
month(Crash.Date) == month(report_date),
Person.Injury.Severity == "K - FATAL INJURY"
) %>%
summarise(n = n()) %>%
pull(n)
fatal_prev <- person_level %>%
filter(
City == "El Paso",
year(Crash.Date) == prev_year,
month(Crash.Date) == month(report_date),
Person.Injury.Severity == "K - FATAL INJURY"
) %>%
summarise(n = n()) %>%
pull(n)
# ----------------------------
# MONTHLY SERIES (CURRENT VS PRIOR YEAR)
# ----------------------------
build_monthly <- function(df, value){
df %>%
mutate(
year = year(Crash.Date),
month = month(Crash.Date)
) %>%
filter(year %in% c(report_year, prev_year)) %>%
group_by(year, month) %>%
summarise(val = {{value}}, .groups="drop") %>%
complete(year, month = 1:12, fill = list(val = 0)) %>%
mutate(
month_lab = factor(month.abb[month], levels = month.abb),
year = factor(year)
)
}
# crashes
crash_plot_data <- build_monthly(crash_level %>% filter(City=="El Paso"),
n_distinct(Crash.ID))
# fatalities
fatal_plot_data <- build_monthly(
person_level %>%
filter(City=="El Paso",
Person.Injury.Severity == "K - FATAL INJURY"),
n()
)
# injuries
injury_plot_data <- build_monthly(
person_level %>%
filter(
City=="El Paso",
!Person.Injury.Severity %in% c(
"99 - UNKNOWN",
"95 - AUTONOMOUS",
"N - NOT INJURED",
"K - FATAL INJURY"
),
!is.na(Person.Injury.Severity)
),
n()
)
# ----------------------------
# CRASHES WITH FATALITIES
# ----------------------------
fatal_crashes_now <- crash_level %>%
filter(
City == "El Paso",
year(Crash.Date) == report_year,
month(Crash.Date) == month(report_date),
Fatal.Crash.Flag == 1
) %>%
summarise(n = n_distinct(Crash.ID)) %>%
pull(n)
# ----------------------------
# INJURY BREAKDOWN
# ----------------------------
injury_breakdown_now <- person_level %>%
filter(
City == "El Paso",
year(Crash.Date) == report_year,
month(Crash.Date) == month(report_date)
) %>%
mutate(
severity = case_when(
Person.Injury.Severity == "K - FATAL INJURY" ~ "Fatal",
Person.Injury.Severity == "A - SUSPECTED SERIOUS INJURY" ~ "Serious",
Person.Injury.Severity == "B - SUSPECTED MINOR INJURY" ~ "Minor",
Person.Injury.Severity == "C - POSSIBLE INJURY" ~ "Possible",
TRUE ~ NA_character_
)
) %>%
filter(!is.na(severity)) %>%
count(severity)
fatal_injuries_now   <- injury_breakdown_now %>% filter(severity=="Fatal") %>% pull(n)
serious_injuries_now <- injury_breakdown_now %>% filter(severity=="Serious") %>% pull(n)
minor_injuries_now   <- injury_breakdown_now %>% filter(severity=="Minor") %>% pull(n)
possible_injuries_now<- injury_breakdown_now %>% filter(severity=="Possible") %>% pull(n)
# remove future months for current year only
filter_future <- function(df){
df %>%
filter(
!(year == report_year & month > month(report_date))
)
}
crash_plot_data  <- filter_future(crash_plot_data)
fatal_plot_data  <- filter_future(fatal_plot_data)
injury_plot_data <- filter_future(injury_plot_data)
# comparison months for brief
comparison_month <- format(
as.Date(paste0(prev_year, "-", month(report_date), "-01")),
"%B %Y"
)
#| title: Crashes
## Color pallete
ytd_colors <- c(
"grey",
"steelblue"
)
p1 <- ggplot(
crash_plot_data,
aes(
x = month_lab,
y = val,
fill = year,
text = paste0(
month.name[match(month_lab, month.abb)], " ", year,
"<br>Total crashes: ", scales::comma(val)
)
)
) +
geom_col(position = position_dodge(width = 0.9)) +
geom_text(
aes(label = val, y = val + 1),
position = position_dodge(width = 0.9),
size = 3
) +
scale_fill_manual(values = ytd_colors) +
scale_y_continuous(
limits = c(0, max(crash_plot_data$val, na.rm = TRUE) * 1.1)
) +
labs(
title = "Alcohol-Related Crashes in El Paso",
x = "",
y = "Total crashes",
fill = ""
) +
theme_minimal() +
theme(legend.position = "bottom")
ggplotly(p1, tooltip = "text") %>%
config(p1, displaylogo = FALSE,
p1, modeBarButtonsToRemove = c('zoom2d', 'pan2d', 'select2d', 'lasso2d', 'zoomin2d', 'zoomout2d', 'hoverCompareCartesian')) %>%
layout(
hoverlabel = list(
bgcolor = "#ffffff",
font = list(color = "black")
),
yaxis = list(
showticklabels = FALSE,
showgrid = TRUE,
zeroline = TRUE
),
title = list(
text = paste0(
"<b>Alcohol-Related Crashes in El Paso</b>",
"<br><sup>2025–Present</sup>"
),
x = 0.5,
xanchor = "center"
),
xaxis = list(
showgrid = FALSE,
zeroline = FALSE
),
annotations = list(
list(
x = 0, y = -0.18,
xref = "paper", yref = "paper",
text = 'Data source: Texas Department of Transportation | Created by <a href="https://epcrimelab.org" target="_blank">El Paso Crime Lab</a>',
showarrow = FALSE,
xanchor = "left",
yanchor = "top",
font = list(size = 10, color = "gray50")
)
)
)
