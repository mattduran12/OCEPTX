group_by(GEOID) %>%
summarise(FatalCrashes = sum(FatalCrashes)),
by = "GEOID"
) %>%
mutate(FatalCrashes = ifelse(is.na(FatalCrashes), 0, FatalCrashes))
# -------------------------
# 9. COLOR SCALE (0 → MAX)
# -------------------------
max_val <- max(blocks_map$FatalCrashes, na.rm = TRUE)
pal <- colorNumeric(
palette = colorRampPalette(c("#f7fbff", "maroon4"))(100),
domain = c(0, max_val),
na.color = "transparent"
)
# -------------------------
# 10. LEAFLET MAP (TOP 20 ONLY)
# -------------------------
leaflet(blocks_map) %>%
addProviderTiles(providers$CartoDB.Positron) %>%
addPolygons(
fillColor = ~pal(FatalCrashes),
fillOpacity = 0.85,
color = "white",
weight = 1,
popup = ~paste0(
"<strong>Block Group:</strong> ", GEOID,
"<br><strong>Fatal Crashes:</strong> ", FatalCrashes
)
) %>%
addLegend(
pal = pal,
values = blocks_map$FatalCrashes,
title = "Fatal Alcohol-Related Crashes (2021–Present)",
position = "bottomright",
opacity = 1
)
library(dplyr)
library(sf)
library(leaflet)
# -------------------------
# 1. ALL ALCOHOL-RELATED CRASHES (2025)
# -------------------------
crash_2025 <- crash_level %>%
filter(Crash.Year == 2025) %>%
mutate(
Latitude = as.numeric(Latitude),
Longitude = as.numeric(Longitude),
hour = as.numeric(substr(Hour.of.Day, 1, 2))
) %>%
filter(!is.na(Latitude), !is.na(Longitude))
# -------------------------
# 2. BLOCK GROUPS
# -------------------------
blocks <- st_read(
"C:/Users/Matt/ASU Dropbox/Matthew Duran/Professional Development/Website/OCEPTX/shape files/Census Block Groups/tl_2025_48_bg.shp",
quiet = TRUE
) %>%
st_make_valid()
crash_sf <- st_as_sf(crash_2025, coords = c("Longitude", "Latitude"), crs = 4326)
blocks <- st_transform(blocks, st_crs(crash_sf))
# -------------------------
# 3. SPATIAL JOIN
# -------------------------
joined <- st_join(crash_sf, blocks, join = st_within)
# -------------------------
# 4. TIME BLOCKS
# -------------------------
joined <- joined %>%
mutate(
time_block = case_when(
hour >= 0  & hour <= 2  ~ "12am–3am",
hour >= 3  & hour <= 5  ~ "3am–6am",
hour >= 6  & hour <= 8  ~ "6am–9am",
hour >= 9  & hour <= 11 ~ "9am–12pm",
hour >= 12 & hour <= 14 ~ "12pm–3pm",
hour >= 15 & hour <= 17 ~ "3pm–6pm",
hour >= 18 & hour <= 20 ~ "6pm–9pm",
hour >= 21 & hour <= 23 ~ "9pm–12am"
)
)
# -------------------------
# 5. AGGREGATE (TIME × BLOCK GROUP)
# -------------------------
tbl <- joined %>%
st_drop_geometry() %>%
group_by(time_block, GEOID) %>%
summarise(n = n(), .groups = "drop")
total_crashes <- sum(tbl$n)
tbl <- tbl %>%
mutate(pct = round(n / total_crashes * 100, 2))
# -------------------------
# 6. TOP 10 COMBINATIONS
# -------------------------
top10_tbl <- tbl %>%
arrange(desc(n)) %>%
slice_head(n = 10)
top10_tbl
# -------------------------
# KEEP ONLY TOP GEOIDS
# -------------------------
top_geoids <- unique(top10_tbl$GEOID)
blocks_top10 <- blocks %>%
filter(GEOID %in% top_geoids)
# aggregate totals per block group (not time-specific for mapping clarity)
map_data <- joined %>%
st_drop_geometry() %>%
group_by(GEOID) %>%
summarise(Crashes = n(), .groups = "drop") %>%
filter(GEOID %in% top_geoids)
blocks_map <- blocks_top10 %>%
left_join(map_data, by = "GEOID") %>%
mutate(Crashes = ifelse(is.na(Crashes), 0, Crashes))
# -------------------------
# COLOR SCALE
# -------------------------
max_val <- max(blocks_map$Crashes, na.rm = TRUE)
pal <- colorNumeric(
palette = colorRampPalette(c("#f7fbff", "maroon4"))(100),
domain = c(0, max_val),
na.color = "transparent"
)
# -------------------------
# MAP
# -------------------------
leaflet(blocks_map) %>%
addProviderTiles(providers$CartoDB.Positron) %>%
addPolygons(
fillColor = ~pal(Crashes),
fillOpacity = 0.85,
color = "white",
weight = 1,
popup = ~paste0(
"<strong>Block Group:</strong> ", GEOID,
"<br><strong>Crashes:</strong> ", Crashes
)
) %>%
addLegend(
pal = pal,
values = blocks_map$Crashes,
title = "Top 10 Alcohol-Related Crash Block Groups (2025)",
position = "bottomright"
) %>%
addControl(
html = "<strong>Top 10 Alcohol-Related Crash Hotspots (2025)</strong>",
position = "topright"
)
library(dplyr)
library(sf)
library(leaflet)
# -------------------------
# 1. ALL ALCOHOL-RELATED CRASHES (2025)
# -------------------------
crash_2025 <- crash_level %>%
filter(Crash.Year == 2025) %>%
mutate(
Latitude = as.numeric(Latitude),
Longitude = as.numeric(Longitude),
hour = as.numeric(substr(Hour.of.Day, 1, 2))
) %>%
filter(!is.na(Latitude), !is.na(Longitude))
# -------------------------
# 2. BLOCK GROUPS
# -------------------------
blocks <- st_read(
"C:/Users/Matt/ASU Dropbox/Matthew Duran/Professional Development/Website/OCEPTX/shape files/Census Block Groups/tl_2025_48_bg.shp",
quiet = TRUE
) %>%
st_make_valid()
crash_sf <- st_as_sf(crash_2025, coords = c("Longitude", "Latitude"), crs = 4326)
blocks <- st_transform(blocks, st_crs(crash_sf))
# -------------------------
# 3. SPATIAL JOIN
# -------------------------
joined <- st_join(crash_sf, blocks, join = st_within)
# -------------------------
# 4. TIME BLOCKS
# -------------------------
joined <- joined %>%
mutate(
time_block = case_when(
hour >= 0  & hour <= 2  ~ "12am–3am",
hour >= 3  & hour <= 5  ~ "3am–6am",
hour >= 6  & hour <= 8  ~ "6am–9am",
hour >= 9  & hour <= 11 ~ "9am–12pm",
hour >= 12 & hour <= 14 ~ "12pm–3pm",
hour >= 15 & hour <= 17 ~ "3pm–6pm",
hour >= 18 & hour <= 20 ~ "6pm–9pm",
hour >= 21 & hour <= 23 ~ "9pm–12am"
)
)
# -------------------------
# 5. AGGREGATE (TIME × BLOCK GROUP)
# -------------------------
tbl <- joined %>%
st_drop_geometry() %>%
group_by(time_block, GEOID) %>%
summarise(n = n(), .groups = "drop")
total_crashes <- sum(tbl$n)
tbl <- tbl %>%
mutate(pct = round(n / total_crashes * 100, 2))
# -------------------------
# 6. TOP 10 COMBINATIONS
# -------------------------
top10_tbl <- tbl %>%
arrange(desc(n)) %>%
slice_head(n = 10)
top_geoids <- unique(top10_tbl$GEOID)
# -------------------------
# 7. FILTER BLOCKS + AGGREGATE FOR MAP
# -------------------------
blocks_top10 <- blocks %>%
filter(GEOID %in% top_geoids)
map_data <- joined %>%
st_drop_geometry() %>%
group_by(GEOID) %>%
summarise(Crashes = n(), .groups = "drop") %>%
filter(GEOID %in% top_geoids)
blocks_map <- blocks_top10 %>%
left_join(map_data, by = "GEOID") %>%
mutate(Crashes = ifelse(is.na(Crashes), 0, Crashes))
# -------------------------
# 8. COLOR SCALE
# -------------------------
max_val <- max(blocks_map$Crashes, na.rm = TRUE)
pal <- colorNumeric(
palette = colorRampPalette(c("#f7fbff", "maroon4"))(100),
domain = c(0, max_val),
na.color = "transparent"
)
# -------------------------
# 9. ADD TIME WINDOW LABEL DATA
# (JOIN BACK TO GEOIDS)
# -------------------------
time_labels <- joined %>%
st_drop_geometry() %>%
group_by(GEOID) %>%
summarise(
time_window = paste(sort(unique(time_block)), collapse = ", "),
.groups = "drop"
)
blocks_map <- blocks_map %>%
left_join(time_labels, by = "GEOID") %>%
mutate(
block_group = substr(GEOID, nchar(GEOID), nchar(GEOID)),
popup_text = paste0(
"<b>Time Window(s):</b> ", time_window, "<br/>",
"<b>GEOID:</b> ", GEOID, "<br/>",
"<b>Census Block Group:</b> ", block_group, "<br/>",
"<b>Crashes:</b> ", Crashes
),
hover_text = paste0(
"Time: ", time_window,
" | BG: ", block_group,
" | Crashes: ", Crashes
)
)
# -------------------------
# 10. MAP
# -------------------------
leaflet(blocks_map) %>%
addProviderTiles(providers$CartoDB.Positron) %>%
addPolygons(
fillColor = ~pal(Crashes),
fillOpacity = 0.85,
color = "white",
weight = 1,
label = ~lapply(hover_text, htmltools::HTML),
labelOptions = labelOptions(
sticky = TRUE,
direction = "auto"
),
popup = ~popup_text
) %>%
addLegend(
pal = pal,
values = blocks_map$Crashes,
title = "Top 10 Alcohol-Related Crash Block Groups (2025)",
position = "bottomright"
) %>%
addControl(
html = "<strong>Top 10 Alcohol-Related Crash Hotspots (2025)</strong>",
position = "topright"
)
# -------------------------
# 1. ALL ALCOHOL-RELATED CRASHES (2025)
# -------------------------
crash_2025 <- crash_level %>%
filter(Crash.Year == 2025) %>%
mutate(
Latitude = as.numeric(Latitude),
Longitude = as.numeric(Longitude),
hour = as.numeric(substr(Hour.of.Day, 1, 2))
) %>%
filter(!is.na(Latitude), !is.na(Longitude))
# -------------------------
# 2. BLOCK GROUPS
# -------------------------
blocks <- st_read(
"C:/Users/Matt/ASU Dropbox/Matthew Duran/Professional Development/Website/OCEPTX/shape files/Census Block Groups/tl_2025_48_bg.shp",
quiet = TRUE
) %>%
st_make_valid()
crash_sf <- st_as_sf(crash_2025, coords = c("Longitude", "Latitude"), crs = 4326)
blocks <- st_transform(blocks, st_crs(crash_sf))
# -------------------------
# 3. SPATIAL JOIN
# -------------------------
joined <- st_join(crash_sf, blocks, join = st_within)
# -------------------------
# 4. TIME BLOCKS
# -------------------------
joined <- joined %>%
mutate(
time_block = case_when(
hour >= 0  & hour <= 2  ~ "12am–3am",
hour >= 3  & hour <= 5  ~ "3am–6am",
hour >= 6  & hour <= 8  ~ "6am–9am",
hour >= 9  & hour <= 11 ~ "9am–12pm",
hour >= 12 & hour <= 14 ~ "12pm–3pm",
hour >= 15 & hour <= 17 ~ "3pm–6pm",
hour >= 18 & hour <= 20 ~ "6pm–9pm",
hour >= 21 & hour <= 23 ~ "9pm–12am"
)
)
# -------------------------
# 5. AGGREGATE (TIME × BLOCK GROUP)
# -------------------------
tbl_time <- joined %>%
st_drop_geometry() %>%
group_by(GEOID, time_block) %>%
summarise(n = n(), .groups = "drop")
total_crashes <- sum(tbl_time$n)
tbl_time <- tbl_time %>%
mutate(pct = n / total_crashes * 100)
# -------------------------
# 6. PEAK RISK TIME (MODAL TIME PER GEOID)
# -------------------------
peak_time <- tbl_time %>%
group_by(GEOID) %>%
slice_max(n, n = 1, with_ties = FALSE) %>%
ungroup() %>%
select(GEOID, peak_time = time_block, peak_crashes = n)
# -------------------------
# 7. TOTAL CRASHES PER GEOID (FOR SHADING)
# -------------------------
geo_totals <- joined %>%
st_drop_geometry() %>%
group_by(GEOID) %>%
summarise(total_crashes = n(), .groups = "drop")
# -------------------------
# 8. TOP 10 BLOCK GROUPS
# -------------------------
top_geoids <- geo_totals %>%
arrange(desc(total_crashes)) %>%
slice_head(n = 10) %>%
pull(GEOID)
# -------------------------
# 9. BUILD MAP DATA
# -------------------------
blocks_map <- blocks %>%
filter(GEOID %in% top_geoids) %>%
left_join(geo_totals, by = "GEOID") %>%
left_join(peak_time, by = "GEOID") %>%
mutate(
block_group = substr(GEOID, nchar(GEOID), nchar(GEOID)),
popup_text = paste0(
"<b>Block Group:</b> ", block_group, "<br/>",
"<b>GEOID:</b> ", GEOID, "<br/>",
"<b>Total Crashes:</b> ", total_crashes, "<br/>",
"<b>Peak Risk Time:</b> ", peak_time, "<br/>",
"<b>Peak Period Crashes:</b> ", peak_crashes
),
hover_text = paste0(
"BG ", block_group,
" | Crashes: ", total_crashes,
" | Peak: ", peak_time
)
)
# -------------------------
# 10. COLOR SCALE (TOTAL CRASHES)
# -------------------------
max_val <- max(blocks_map$total_crashes, na.rm = TRUE)
pal <- colorNumeric(
palette = colorRampPalette(c("#f7fbff", "maroon4"))(100),
domain = c(0, max_val),
na.color = "transparent"
)
# -------------------------
# 11. MAP
# -------------------------
leaflet(blocks_map) %>%
addProviderTiles(providers$CartoDB.Positron) %>%
addPolygons(
fillColor = ~pal(total_crashes),
fillOpacity = 0.85,
color = "white",
weight = 1,
label = ~lapply(hover_text, htmltools::HTML),
labelOptions = labelOptions(
sticky = TRUE,
direction = "auto"
),
popup = ~popup_text
) %>%
addLegend(
pal = pal,
values = blocks_map$total_crashes,
title = "Alcohol-Related Crashes (Top 10 Block Groups, 2025)",
position = "bottomright"
) %>%
addControl(
html = "<strong>Crash Hotspots + Peak Risk Time (2025)</strong>",
position = "topright"
)
